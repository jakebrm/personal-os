# Personal OS — environment variables
# Copy to .env.local and fill in. Only the REQUIRED block is needed to boot.

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Supabase project (create one free at https://supabase.com, then run the SQL
# files in supabase/migrations in order — see SETUP.md)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Login: the dashboard is protected by a single password + signed session cookie
DASHBOARD_PASSWORD=
AUTH_SECRET=            # any long random string, e.g. `openssl rand -hex 32`

# ── RECOMMENDED ───────────────────────────────────────────────────────────────
# Your IANA timezone — controls when "today" rolls over for habits, journal,
# and stats. Unset, days flip at UTC midnight.
NEXT_PUBLIC_USER_TIMEZONE=      # e.g. America/New_York

# Weather card — your coordinates (Open-Meteo, free, no API key needed)
NEXT_PUBLIC_WEATHER_LAT=        # e.g. 40.71
NEXT_PUBLIC_WEATHER_LON=        # e.g. -74.01
NEXT_PUBLIC_WEATHER_LABEL=      # optional place name shown in the Weather tab, e.g. "Brooklyn, NY"

# ── OPTIONAL INTEGRATIONS ─────────────────────────────────────────────────────
# AI chat (nutritionist) — https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Dashboard greeting
NEXT_PUBLIC_OWNER_NAME=     # your first name, shown in the dashboard greeting

# Brain embeddings/search
OPENAI_API_KEY=

# Calendar card/agenda — your Google Calendar's secret iCal URL
GOOGLE_CALENDAR_ICAL_URL=

# Optional secondary calendars — comma-separated "Name|ical-url" pairs.
# Shown muted + tagged with Name in the Calendar card; excluded from event stats.
# e.g. CALENDAR_EXTRA_FEEDS="Work|https://…/basic.ics,Family|https://…/basic.ics"
CALENDAR_EXTRA_FEEDS=

# Friends' birthdays as a subscribable calendar (any long random string).
# Subscribe from Google Calendar / iOS to:
#   https://<host>/api/calendar/birthdays.ics?token=BIRTHDAY_ICS_TOKEN
# (Don't add it to CALENDAR_EXTRA_FEEDS — birthdays already show in the dashboard.)
BIRTHDAY_ICS_TOKEN=

# Training sync — Strava API app (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# Training sync — intervals.icu
INTERVALS_API_KEY=
INTERVALS_ATHLETE_ID=

# Telegram capture bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
TELEGRAM_WEBHOOK_SECRET=

# Webhook/cron protection (only needed if you deploy with crons/webhooks)
CRON_SECRET=
STARFIT_WEBHOOK_SECRET=
APPLE_EXPORT_SECRET=  # Bearer token for the Health Auto Export iOS app (POST /api/health/apple-export)
